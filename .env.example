# PathWiser · environment variables example
# Copy this file to `.env.local` and fill in real values. `.env.local` is git-ignored.

# ─── Supabase ───────────────────────────────────────────────
# From Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGci..."
# Server-only. Never expose to the client. Used for migrations + admin ops.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci..."

# ─── AI Provider (default: Google AI Studio · Gemini) ──────
# From aistudio.google.com/apikey — free tier, no credit card required.
# Talentbank's engineers can swap this for their internal AI by changing this
# single env var and (optionally) the provider file at lib/ai/gemini.ts.
GEMINI_API_KEY="AIzaSy..."

# Model IDs — override to point at a different Gemini variant if quota changes
GEMINI_EMBEDDING_MODEL="text-embedding-004"
GEMINI_CHAT_MODEL="gemini-1.5-flash"

# ─── Adoption hooks (Talentbank plugs in later) ────────────
# Provider selector — 'gemini' (default) | 'huggingface' | 'openai' | 'talentbank-internal'
AI_PROVIDER="gemini"

# Local development uses the disclosed in-memory demo corpus by default, even
# if credentials are present. Set this only when intentionally testing the
# Supabase + Gemini full-mode path on a connected development machine.
ALLOW_FULL_MODE="false"

# Community release controls. Production should require accounts and keep the
# hackathon-only cross-persona switch disabled.
AUTH_MODE="required"
NEXT_PUBLIC_ENABLE_JUDGE_MODE="false"

# Keep true while using the bundled modelled corpus. Set false only after a
# governed, consented trajectory import has replaced it.
EVIDENCE_CORPUS_SYNTHETIC="true"
